{
  "name": "agent-paste-monorepo",
  "license": "Apache-2.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "cli:dev": "pnpm --filter @zaks-io/agent-paste dev --",
    "dev:apex": "pnpm --filter @agent-paste/apex preview:watch",
    "dev:all": "pnpm build && node scripts/local-mvp-server.mjs",
    "dev:web": "node scripts/dev-web-local.mjs",
    "bootstrap:preview": "node scripts/bootstrap-secrets.mjs preview",
    "bootstrap:production": "node scripts/bootstrap-secrets.mjs production",
    "secrets:rotate:content-signing:preview": "node scripts/rotate-versioned-secret.mjs content-signing preview",
    "secrets:rotate:content-signing:production": "node scripts/rotate-versioned-secret.mjs content-signing production",
    "secrets:rotate:upload-signing:preview": "node scripts/rotate-versioned-secret.mjs upload-signing preview",
    "secrets:rotate:upload-signing:production": "node scripts/rotate-versioned-secret.mjs upload-signing production",
    "secrets:rotate:api-key-pepper:preview": "node scripts/rotate-versioned-secret.mjs api-key-pepper preview",
    "secrets:rotate:api-key-pepper:production": "node scripts/rotate-versioned-secret.mjs api-key-pepper production",
    "secrets:rotate:artifact-bytes:preview": "node scripts/rotate-versioned-secret.mjs artifact-bytes-encryption preview",
    "secrets:rotate:artifact-bytes:production": "node scripts/rotate-versioned-secret.mjs artifact-bytes-encryption production",
    "secrets:rotate:workos-api-key:preview": "node scripts/rotate-workos-secrets.mjs workos-api-key preview",
    "secrets:rotate:workos-api-key:production": "node scripts/rotate-workos-secrets.mjs workos-api-key production",
    "secrets:rotate:workos-cookie:preview": "node scripts/rotate-workos-secrets.mjs workos-cookie-password preview",
    "secrets:rotate:workos-cookie:production": "node scripts/rotate-workos-secrets.mjs workos-cookie-password production",
    "bootstrap:live": "pnpm bootstrap:production",
    "ci:check": "pnpm verify",
    "cli:test": "pnpm --filter @zaks-io/agent-paste test",
    "deploy:preview": "node scripts/deploy.mjs preview",
    "deploy:production": "node scripts/deploy.mjs production",
    "deploy:live": "pnpm deploy:production",
    "secrets:local": "node scripts/deploy.mjs local",
    "security:attest": "node scripts/security-attest.mjs",
    "format": "pnpm format:code && pnpm format:docs",
    "format:code": "biome format --write .",
    "format:code:check": "biome format .",
    "format:docs": "prettier --write \"**/*.md\"",
    "format:docs:check": "prettier --check \"**/*.md\"",
    "hooks:install": "node scripts/install-hooks.mjs",
    "hooks:run:pre-commit": "lefthook run pre-commit",
    "hooks:run:pre-push": "lefthook run pre-push --force",
    "dupes": "node scripts/jscpd-check.mjs",
    "knip": "node scripts/knip-check.mjs",
    "lint": "turbo run lint",
    "openapi:check": "pnpm --filter @agent-paste/contracts openapi:check",
    "openapi:write": "pnpm --filter @agent-paste/contracts openapi:write",
    "migrate:preview": "node scripts/migrate.mjs preview",
    "migrate:production": "node scripts/migrate.mjs production",
    "migrate:live": "pnpm migrate:production",
    "prepare": "node scripts/install-hooks.mjs",
    "smoke:local": "pnpm build && node scripts/smoke-local-mvp.mjs",
    "smoke:local:patch": "pnpm build && node scripts/smoke-local-patch.mjs",
    "smoke:ci:postgres": "pnpm build && node scripts/smoke-ci-postgres.mjs",
    "smoke:preview": "pnpm build && node scripts/smoke-hosted.mjs preview",
    "smoke:preview:ephemeral": "pnpm build && node scripts/smoke-hosted-ephemeral.mjs preview",
    "smoke:production": "pnpm build && node scripts/smoke-hosted.mjs production",
    "smoke:production:ephemeral": "pnpm build && node scripts/smoke-hosted-ephemeral.mjs production",
    "smoke:pr": "pnpm build && node scripts/smoke-hosted.mjs pr",
    "smoke:pr:ephemeral": "pnpm build && node scripts/smoke-hosted-ephemeral.mjs pr",
    "smoke:web": "pnpm build && node scripts/smoke-web-api.mjs",
    "smoke:mcp": "pnpm build && node scripts/smoke-mcp.mjs local",
    "smoke:mcp:preview": "pnpm build && node scripts/smoke-mcp.mjs preview",
    "smoke:mcp:production": "pnpm build && node scripts/smoke-mcp.mjs production",
    "smoke:preview:readonly": "pnpm build && node scripts/smoke-prod-readonly.mjs preview",
    "smoke:prod:readonly": "pnpm build && node scripts/smoke-prod-readonly.mjs production",
    "lighthouse:dashboard-a11y": "node scripts/lighthouse-dashboard-a11y.mjs",
    "setup:worktree": "node scripts/setup-worktree.mjs",
    "setup:codex": "node scripts/setup-worktree.mjs",
    "test": "turbo run test",
    "test:scripts": "vitest run --config vitest.scripts.config.ts",
    "test:coverage": "node scripts/clean-coverage.mjs && turbo run test:coverage && node scripts/merge-coverage.mjs",
    "test:coverage:strict": "node scripts/clean-coverage.mjs && turbo run test:coverage --force && node scripts/merge-coverage.mjs",
    "typecheck": "turbo run typecheck",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "verify": "pnpm format:code:check && pnpm format:docs:check && pnpm knip && pnpm dupes && turbo run lint typecheck test openapi:check db:check && pnpm typecheck:scripts && pnpm test:scripts"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@cloudflare/workers-types": "^4.20260521.1",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "catalog:",
    "@workos/authkit-session": "0.5.2",
    "chrome-launcher": "^1.2.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "lighthouse": "^12.8.2",
    "prettier": "3.5.3",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.94.0"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.12",
      "@babel/core": "^7.29.7",
      "@cloudflare/vite-plugin>ws": "^8.21.0",
      "jsdom>ws": "^8.21.0",
      "miniflare>ws": "^8.21.0",
      "puppeteer-core>ws": "^8.21.0",
      "xmlbuilder2>js-yaml": "^4.2.0"
    }
  },
  "optionalDependencies": {
    "@cloudflare/workerd-darwin-64": "1.20260520.1",
    "@cloudflare/workerd-darwin-arm64": "1.20260520.1",
    "@cloudflare/workerd-linux-64": "1.20260520.1",
    "@cloudflare/workerd-linux-arm64": "1.20260520.1",
    "@cloudflare/workerd-windows-64": "1.20260520.1",
    "lefthook-darwin-arm64": "2.1.8",
    "lefthook-darwin-x64": "2.1.8",
    "lefthook-linux-arm64": "2.1.8",
    "lefthook-linux-x64": "2.1.8",
    "lefthook-windows-arm64": "2.1.8",
    "lefthook-windows-x64": "2.1.8"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
