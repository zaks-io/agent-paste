{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**",
      "!.agents",
      "!node_modules",
      "!dist",
      "!**/dist",
      "!.turbo",
      "!.wrangler",
      "!**/worker-configuration.d.ts",
      "!**/routeTree.gen.ts",
      "!packages/contracts/openapi/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["apps/web/src/routes/al.*"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@workos/authkit-tanstack-react-start": "Access Link routes must not import auth modules (ADR 0033).",
                  "@workos/authkit-session": "Access Link routes must not import auth modules (ADR 0033).",
                  "@tanstack/react-start/server": "Access Link routes must not import sealed-session helpers (ADR 0033)."
                }
              }
            }
          }
        }
      }
    }
  ]
}
