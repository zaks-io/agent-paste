{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"]
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"]
    }
  },
  "upload_source_maps": true,
  "vars": {
    "AGENT_PASTE_ENV": "dev",
    "MCP_RESOURCE": "https://mcp.agent-paste.sh",
    "WORKOS_MCP_AUDIENCE": "https://mcp.agent-paste.sh"
  },
  "services": [
    {
      "binding": "API",
      "service": "agent-paste-api"
    },
    {
      "binding": "UPLOAD",
      "service": "agent-paste-upload"
    }
  ],
  "env": {
    "preview": {
      "name": "agent-paste-mcp-preview",
      "workers_dev": true,
      "routes": [
        {
          "pattern": "mcp.preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "preview",
        "MCP_RESOURCE": "https://mcp.preview.agent-paste.sh",
        "MCP_AUTHORIZATION_SERVER": "https://courageous-milestone-75-staging.authkit.app",
        "WORKOS_MCP_AUDIENCE": "https://mcp.preview.agent-paste.sh",
        "WORKOS_MCP_JWKS_URL": "https://courageous-milestone-75-staging.authkit.app/oauth2/jwks",
        "WORKOS_MCP_ISSUER": "https://courageous-milestone-75-staging.authkit.app"
      },
      "services": [
        {
          "binding": "API",
          "service": "agent-paste-api-preview"
        },
        {
          "binding": "UPLOAD",
          "service": "agent-paste-upload-preview"
        }
      ]
    },
    "production": {
      "name": "agent-paste-mcp-production",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "mcp.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "production",
        "MCP_RESOURCE": "https://mcp.agent-paste.sh",
        "MCP_AUTHORIZATION_SERVER": "https://soulful-path-50.authkit.app",
        "WORKOS_MCP_AUDIENCE": "https://mcp.agent-paste.sh",
        "WORKOS_MCP_JWKS_URL": "https://soulful-path-50.authkit.app/oauth2/jwks",
        "WORKOS_MCP_ISSUER": "https://soulful-path-50.authkit.app"
      },
      "services": [
        {
          "binding": "API",
          "service": "agent-paste-api-production"
        },
        {
          "binding": "UPLOAD",
          "service": "agent-paste-upload-production"
        }
      ]
    }
  }
}
