{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-web",
  "main": "src/server.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"]
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"]
    }
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "vars": {
    "API_BASE_URL": "http://127.0.0.1:8787",
    "CONTENT_BASE_URL": "http://127.0.0.1:8789",
    "STREAM_BASE_URL": "http://127.0.0.1:8791",
    "AGENT_PASTE_ENV": "dev",
    "WORKOS_CLIENT_ID": "",
    "WORKOS_REDIRECT_URI": "http://localhost:5173/api/auth/callback",
    "WORKOS_COOKIE_NAME": "__agp_session",
    "WORKOS_COOKIE_SAME_SITE": "lax",
    "WEB_BASE_URL": "http://localhost:5173",
    "TURNSTILE_SITE_KEY": "1x00000000000000000000AA",
    "CF_WEB_ANALYTICS_TOKEN": ""
  },
  "env": {
    "preview": {
      "name": "agent-paste-web-preview",
      // Per ADR 0078; routing source of truth: scripts/lib/secret-routing.mjs.
      "secrets": {
        "required": ["WORKOS_API_KEY", "WORKOS_COOKIE_PASSWORD"]
      },
      "workers_dev": true,
      "routes": [
        {
          "pattern": "app.preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "preview",
        "API_BASE_URL": "https://agent-paste-api-preview.isaac-a46.workers.dev",
        "CONTENT_BASE_URL": "https://agent-paste-content-preview.isaac-a46.workers.dev",
        "STREAM_BASE_URL": "https://stream.preview.agent-paste.sh",
        "WORKOS_CLIENT_ID": "client_01KSAJTF1EX1YZCCXJS9B0GJ46",
        "WORKOS_REDIRECT_URI": "https://app.preview.agent-paste.sh/api/auth/callback",
        "WORKOS_COOKIE_NAME": "__agp_session",
        "WORKOS_COOKIE_SAME_SITE": "lax",
        "WEB_BASE_URL": "https://app.preview.agent-paste.sh",
        "TURNSTILE_SITE_KEY": "0x4AAAAAADdwTR9FFmnKY9lL",
        "CF_WEB_ANALYTICS_TOKEN": "4be1fdfc8b624bb7b9db72e738d561d0"
      },
      "services": [
        {
          "binding": "API",
          "service": "agent-paste-api-preview"
        }
      ]
    },
    "production": {
      "name": "agent-paste-web-production",
      "secrets": {
        "required": ["WORKOS_API_KEY", "WORKOS_COOKIE_PASSWORD"]
      },
      "workers_dev": false,
      "routes": [
        {
          "pattern": "app.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "production",
        "API_BASE_URL": "https://api.agent-paste.sh",
        "CONTENT_BASE_URL": "https://usercontent.agent-paste.sh",
        "STREAM_BASE_URL": "https://stream.agent-paste.sh",
        "WORKOS_CLIENT_ID": "client_01KSED0F1X2MZ0WCKNNQR6FY2X",
        "WORKOS_REDIRECT_URI": "https://app.agent-paste.sh/api/auth/callback",
        "WORKOS_COOKIE_NAME": "__agp_session",
        "WORKOS_COOKIE_SAME_SITE": "lax",
        "WEB_BASE_URL": "https://app.agent-paste.sh",
        "TURNSTILE_SITE_KEY": "0x4AAAAAADdwQJT2MNI2Fcve",
        "CF_WEB_ANALYTICS_TOKEN": "4be1fdfc8b624bb7b9db72e738d561d0"
      },
      "services": [
        {
          "binding": "API",
          "service": "agent-paste-api-production"
        }
      ]
    }
  }
}
