{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["CLOUDFLARE_ENV", "SENTRY_AUTH_TOKEN"],
      // @cloudflare/vite-plugin writes this deploy-config redirect during `vite
      // build`; without it a cache-restored build makes `wrangler deploy` fall
      // back to wrangler.jsonc (main: src/server.ts) and fail on TanStack
      // virtual modules.
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**", ".output/**", ".wrangler/deploy/config.json"]
    },
    "deploy:preview": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CLOUDFLARE_ACCOUNT_ID", "CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ENV"]
    },
    "deploy:production": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CLOUDFLARE_ACCOUNT_ID", "CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ENV"]
    }
  }
}
