{
  "name": "@agent-paste/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "pnpm typecheck",
    "deploy:live": "pnpm deploy:production",
    "deploy:preview": "CLOUDFLARE_ENV=preview pnpm build && CLOUDFLARE_ENV=preview wrangler deploy",
    "deploy:production": "CLOUDFLARE_ENV=production pnpm build && CLOUDFLARE_ENV=production wrangler deploy",
    "dev": "vite dev",
    "lint": "biome lint .",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typegen": "wrangler types --config wrangler.jsonc --env preview"
  },
  "dependencies": {
    "@agent-paste/contracts": "workspace:*",
    "@agent-paste/worker-runtime": "workspace:*",
    "@fontsource-variable/hanken-grotesk": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@sentry/cloudflare": "^10.53.1",
    "@tanstack/react-router": "^1.121.0",
    "@tanstack/react-start": "^1.121.0",
    "@workos/authkit-tanstack-react-start": "^0.8.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.0",
    "@cloudflare/workers-types": "^4.20260521.1",
    "@tailwindcss/vite": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.7",
    "typescript": "catalog:",
    "vite": "^7.0.0",
    "vitest": "catalog:",
    "wrangler": "^4.93.1"
  }
}
