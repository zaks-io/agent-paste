{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-content",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"]
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"]
    }
  },
  "upload_source_maps": true,
  "vars": {
    "AGENT_PASTE_ENV": "dev",
    "CONTENT_SIGNING_KID": "v1"
  },
  "r2_buckets": [
    {
      // Content reads artifact bytes only; it has no DB binding.
      "binding": "ARTIFACTS",
      "bucket_name": "agent-paste-artifacts-dev"
    }
  ],
  "kv_namespaces": [
    {
      // Denylist reads per ADR 0057.
      "binding": "DENYLIST",
      "id": "00000000000000000000000000000000"
    }
  ],
  "ratelimits": [
    {
      "name": "ARTIFACT_RATE_LIMIT",
      "namespace_id": "1000003",
      "simple": {
        "limit": 60,
        "period": 60
      }
    }
  ],
  "env": {
    "preview": {
      "name": "agent-paste-content-preview",
      // Per ADR 0078; routing source of truth: scripts/lib/secret-routing.mjs.
      "secrets": {
        "required": ["ARTIFACT_BYTES_ENCRYPTION_KEY", "CONTENT_SIGNING_SECRET"]
      },
      "workers_dev": true,
      "routes": [
        {
          "pattern": "usercontent.preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "preview",
        "CONTENT_SIGNING_KID": "v1",
        "DOCS_BASE_URL": ""
      },
      "r2_buckets": [
        {
          "binding": "ARTIFACTS",
          "bucket_name": "agent-paste-artifacts-preview"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "DENYLIST",
          "id": "5780695433d4494897dcbb78bcb4f180"
        }
      ],
      "ratelimits": [
        {
          "name": "ARTIFACT_RATE_LIMIT",
          "namespace_id": "2000003",
          "simple": {
            "limit": 60,
            "period": 60
          }
        }
      ]
    },
    "production": {
      "name": "agent-paste-content-production",
      "secrets": {
        "required": ["ARTIFACT_BYTES_ENCRYPTION_KEY", "CONTENT_SIGNING_SECRET"]
      },
      "workers_dev": false,
      "routes": [
        {
          "pattern": "usercontent.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "production",
        "CONTENT_SIGNING_KID": "v1",
        "DOCS_BASE_URL": ""
      },
      "r2_buckets": [
        {
          "binding": "ARTIFACTS",
          "bucket_name": "agent-paste-artifacts-production"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "DENYLIST",
          "id": "86d8b139223e45108d320533277a235d"
        }
      ],
      "ratelimits": [
        {
          "name": "ARTIFACT_RATE_LIMIT",
          "namespace_id": "3000003",
          "simple": {
            "limit": 60,
            "period": 60
          }
        }
      ]
    }
  }
}
