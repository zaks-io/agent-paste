{
  "name": "agent-paste",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-paste": "./dist/src/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm typecheck",
    "dev": "pnpm build && node dist/src/index.js",
    "lint": "biome lint .",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-paste/api-client": "workspace:*",
    "@agent-paste/contracts": "workspace:*",
    "@agent-paste/storage": "workspace:*",
    "@napi-rs/keyring": "1.3.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
