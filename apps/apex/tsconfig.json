{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "WebWorker"],
    "outDir": "dist",
    "rootDir": "src",
    "types": ["vitest/globals"],
    "jsx": "react-jsx",
