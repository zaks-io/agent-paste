{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-apex",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "vars": {
    "AGENT_PASTE_ENV": "dev"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "not_found_handling": "none",
    "run_worker_first": true
  },
  "env": {
    "preview": {
      "name": "agent-paste-apex-preview",
      "workers_dev": true,
      "routes": [
        {
          "pattern": "preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "preview"
      }
    },
    "production": {
      "name": "agent-paste-apex-production",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "production"
      }
    }
  }
}
