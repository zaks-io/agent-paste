{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-apex",
  "main": "src/server.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "minify": true,
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"]
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"]
    }
  },
  "upload_source_maps": true,
  "vars": {
    "AGENT_PASTE_ENV": "dev"
  },
  "analytics_engine_datasets": [
    {
      "binding": "FUNNEL_EVENTS",
      "dataset": "agent_paste_funnel_events_dev"
    }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
    "not_found_handling": "none",
    // Prerender emits dir/index.html, which the asset server would otherwise
    // serve at /about/ and 307-redirect /about -> /about/. Our canonical tags
    // and sitemap advertise the no-slash form, so drop the slash to make the
    // served URL match the advertised one (no-slash 200, /about/ -> /about).
    "html_handling": "drop-trailing-slash",
    "run_worker_first": true
  },
  "env": {
    "preview": {
      "name": "agent-paste-apex-preview",
      "workers_dev": true,
      "routes": [
        {
          "pattern": "preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "preview",
        "CF_WEB_ANALYTICS_TOKEN": "4be1fdfc8b624bb7b9db72e738d561d0",
        "BILLING_ENABLED": "true"
      },
      "analytics_engine_datasets": [
        {
          "binding": "FUNNEL_EVENTS",
          "dataset": "agent_paste_funnel_events_preview"
        }
      ]
    },
    "production": {
      "name": "agent-paste-apex-production",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "production",
        "CF_WEB_ANALYTICS_TOKEN": "4be1fdfc8b624bb7b9db72e738d561d0",
        "BILLING_ENABLED": "false"
      },
      "analytics_engine_datasets": [
        {
          "binding": "FUNNEL_EVENTS",
          "dataset": "agent_paste_funnel_events_production"
        }
      ]
    }
  }
}
