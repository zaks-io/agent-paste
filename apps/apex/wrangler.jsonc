{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-apex",
  "main": "src/server.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"]
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"]
    }
  },
  "upload_source_maps": true,
  "vars": {
    "AGENT_PASTE_ENV": "dev"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
    "not_found_handling": "none",
    "run_worker_first": true
  },
  "env": {
    "preview": {
      "name": "agent-paste-apex-preview",
      "workers_dev": true,
      "routes": [
        {
          "pattern": "preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "preview",
        "CF_WEB_ANALYTICS_TOKEN": "4be1fdfc8b624bb7b9db72e738d561d0",
        "BILLING_ENABLED": "true"
      }
    },
    "production": {
      "name": "agent-paste-apex-production",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "AGENT_PASTE_ENV": "production",
        "CF_WEB_ANALYTICS_TOKEN": "4be1fdfc8b624bb7b9db72e738d561d0",
        "BILLING_ENABLED": "false"
      }
    }
  }
}
