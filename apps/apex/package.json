{
  "name": "@agent-paste/apex",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/prerender.mjs",
    "check": "pnpm typecheck",
    "deploy:live": "pnpm deploy:production",
    "deploy:preview": "pnpm build && wrangler deploy --config wrangler.jsonc --env preview",
    "deploy:production": "pnpm build && wrangler deploy --config wrangler.jsonc --env production",
    "dev": "wrangler dev --config wrangler.jsonc",
    "lint": "biome lint .",
    "preview": "vite preview --outDir dist/client",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.node.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typegen": "wrangler types src/worker-configuration.d.ts --config wrangler.jsonc --env preview"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.1",
    "@tailwindcss/vite": "^4.1.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "catalog:",
    "vite": "^7.0.0",
    "vitest": "catalog:",
    "wrangler": "^4.94.0"
  },
  "dependencies": {
    "@agent-paste/config": "workspace:*",
    "@agent-paste/plans": "workspace:*",
    "@agent-paste/ui": "workspace:*",
    "@agent-paste/worker-runtime": "workspace:*",
    "@sentry/cloudflare": "^10.53.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
