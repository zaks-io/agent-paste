{
  "name": "@agent-paste/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm typecheck",
    "deploy:live": "wrangler deploy --config wrangler.jsonc --env live",
    "deploy:preview": "wrangler deploy --config wrangler.jsonc --env preview",
    "dev": "wrangler dev --config wrangler.jsonc",
    "test": "vitest run",
    "typegen": "wrangler types src/worker-configuration.d.ts --config wrangler.jsonc --env preview",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@agent-paste/auth": "workspace:*",
    "@agent-paste/db": "workspace:*"
  }
}
