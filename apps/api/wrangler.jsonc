{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "agent-paste-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"]
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"]
    }
  },
  "upload_source_maps": true,
  "vars": {
    "AGENT_PASTE_ENV": "dev",
    "API_KEY_ENV": "preview",
    "API_BASE_URL": "http://127.0.0.1:8787",
    "CONTENT_BASE_URL": "http://127.0.0.1:8789",
    "CLEANUP_BATCH_SIZE": "100",
    "DOCS_BASE_URL": "",
    "WORKOS_CLIENT_ID": "",
    "WORKOS_CLI_AUDIENCE": "",
    "WORKOS_MCP_AUDIENCE": "https://mcp.agent-paste.sh",
    "CF_ACCESS_TEAM_DOMAIN": ""
  },
  "r2_buckets": [
    {
      "binding": "ARTIFACTS",
      "bucket_name": "agent-paste-artifacts-dev"
    }
  ],
  "kv_namespaces": [
    {
      // Denylist writes per ADR 0057.
      "binding": "DENYLIST",
      "id": "00000000000000000000000000000000"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ARTIFACT_LIVE",
        "class_name": "ArtifactLiveUpdates",
        "script_name": "agent-paste-stream"
      },
      {
        "name": "WRITE_ALLOWANCE",
        "class_name": "WorkspaceWriteAllowance"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-write-allowance",
      "new_sqlite_classes": ["WorkspaceWriteAllowance"]
    }
  ],
  "ratelimits": [
    {
      "name": "ACTOR_RATE_LIMIT",
      "namespace_id": "1000001",
      "simple": {
        "limit": 60,
        "period": 60
      }
    },
    {
      "name": "WORKSPACE_BURST_CAP",
      "namespace_id": "1000002",
      "simple": {
        "limit": 300,
        "period": 10
      }
    },
    {
      "name": "ARTIFACT_RATE_LIMIT",
      "namespace_id": "1000003",
      "simple": {
        "limit": 60,
        "period": 60
      }
    },
    {
      "name": "EPHEMERAL_PROVISION_IP_RATE_LIMIT",
      "namespace_id": "1000004",
      "simple": {
        "limit": 10,
        "period": 60
      }
    },
    {
      "name": "EPHEMERAL_PROVISION_GLOBAL_RATE_LIMIT",
      "namespace_id": "1000005",
      "simple": {
        "limit": 17,
        "period": 60
      }
    }
  ],
  "env": {
    "preview": {
      "name": "agent-paste-api-preview",
      "workers_dev": true,
      // Per ADR 0078: deploy fails if any of these are missing. Source of truth
      // for routing is scripts/lib/secret-routing.mjs.
      "secrets": {
        "required": ["API_KEY_PEPPER_V1", "CONTENT_SIGNING_SECRET", "EPHEMERAL_POW_SECRET", "STREAM_INTERNAL_SECRET"]
      },
      "routes": [
        {
          "pattern": "api.preview.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "API_KEY_ENV": "preview",
        "API_BASE_URL": "https://agent-paste-api-preview.isaac-a46.workers.dev",
        "CONTENT_BASE_URL": "https://agent-paste-content-preview.isaac-a46.workers.dev",
        "CLEANUP_BATCH_SIZE": "100",
        "AGENT_PASTE_ENV": "preview",
        "DOCS_BASE_URL": "",
        "WORKOS_CLIENT_ID": "client_01KSAJTF1EX1YZCCXJS9B0GJ46",
        // AuthKit User Management session tokens (forwarded by the web app) are
        // issued by api.workos.com/user_management/{env default client}. That client
        // is the environment's default client (== WORKOS_CLI_AUDIENCE), deliberately
        // NOT WORKOS_CLIENT_ID: the latter is a separate AuthKit client used only to
        // build the JWKS URL, and signing keys are shared environment-wide. Not the
        // authkit.app domain either (that is the CLI/Connect issuer below).
        "WORKOS_ISSUER": "https://api.workos.com/user_management/client_01KSAGD5FCYJ13KSQ7SKVBDKNB",
        // `agent-paste login` (WorkOS Public OAuth / Connect app) tokens verify
        // against the authkit.app JWKS and issuer, not the api.workos.com dashboard
        // path. WORKOS_CLI_AUDIENCE is the environment OIDC client stamped into the
        // token `aud` (WorkOS exposes no claim for the OAuth app id itself). All
        // public identifiers; safe in vars.
        "WORKOS_CLI_AUDIENCE": "client_01KSAGD5FCYJ13KSQ7SKVBDKNB",
        "WORKOS_CLI_JWKS_URL": "https://courageous-milestone-75-staging.authkit.app/oauth2/jwks",
        "WORKOS_CLI_ISSUER": "https://courageous-milestone-75-staging.authkit.app",
        "WORKOS_MCP_AUDIENCE": "https://mcp.agent-paste.sh",
        "WORKOS_MCP_JWKS_URL": "https://courageous-milestone-75-staging.authkit.app/oauth2/jwks",
        "WORKOS_MCP_ISSUER": "https://courageous-milestone-75-staging.authkit.app",
        "CF_ACCESS_TEAM_DOMAIN": ""
      },
      "hyperdrive": [
        {
          "binding": "DB",
          "id": "7da9ea500b534f3fa522460c8a9f2efc"
        }
      ],
      "r2_buckets": [
        {
          "binding": "ARTIFACTS",
          "bucket_name": "agent-paste-artifacts-preview"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "DENYLIST",
          "id": "5780695433d4494897dcbb78bcb4f180"
        }
      ],
      "ratelimits": [
        {
          "name": "ACTOR_RATE_LIMIT",
          "namespace_id": "2000001",
          "simple": {
            "limit": 60,
            "period": 60
          }
        },
        {
          "name": "WORKSPACE_BURST_CAP",
          "namespace_id": "2000002",
          "simple": {
            "limit": 300,
            "period": 10
          }
        },
        {
          "name": "ARTIFACT_RATE_LIMIT",
          "namespace_id": "2000003",
          "simple": {
            "limit": 60,
            "period": 60
          }
        },
        {
          "name": "EPHEMERAL_PROVISION_IP_RATE_LIMIT",
          "namespace_id": "2000004",
          "simple": {
            "limit": 10,
            "period": 60
          }
        },
        {
          "name": "EPHEMERAL_PROVISION_GLOBAL_RATE_LIMIT",
          "namespace_id": "2000005",
          "simple": {
            "limit": 17,
            "period": 60
          }
        }
      ],
      "queues": {
        "producers": [
          { "queue": "bundle-generate-preview", "binding": "BUNDLE_GENERATE_QUEUE" },
          { "queue": "safety-scan-preview", "binding": "SAFETY_SCAN_QUEUE" }
        ]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "ARTIFACT_LIVE",
            "class_name": "ArtifactLiveUpdates",
            "script_name": "agent-paste-stream-preview"
          },
          {
            "name": "WRITE_ALLOWANCE",
            "class_name": "WorkspaceWriteAllowance"
          }
        ]
      }
    },
    "production": {
      "name": "agent-paste-api-production",
      "workers_dev": false,
      "secrets": {
        "required": ["API_KEY_PEPPER_V1", "CONTENT_SIGNING_SECRET", "EPHEMERAL_POW_SECRET", "STREAM_INTERNAL_SECRET"]
      },
      "routes": [
        {
          "pattern": "api.agent-paste.sh",
          "custom_domain": true
        }
      ],
      "vars": {
        "API_KEY_ENV": "production",
        "API_BASE_URL": "https://api.agent-paste.sh",
        "CONTENT_BASE_URL": "https://usercontent.agent-paste.sh",
        "CLEANUP_BATCH_SIZE": "100",
        "AGENT_PASTE_ENV": "production",
        "DOCS_BASE_URL": "",
        "WORKOS_CLIENT_ID": "client_01KSED0F1X2MZ0WCKNNQR6FY2X",
        // AuthKit User Management session tokens (forwarded by the web app) are
        // issued by api.workos.com/user_management/{env default client}. That client
        // is the environment's default client (== WORKOS_CLI_AUDIENCE), deliberately
        // NOT WORKOS_CLIENT_ID: the latter is a separate AuthKit client used only to
        // build the JWKS URL, and signing keys are shared environment-wide. Not the
        // authkit.app domain either (that is the CLI/Connect issuer below). Confirmed
        // against the prod worker tail.
        "WORKOS_ISSUER": "https://api.workos.com/user_management/client_01KSAGD5VSVFATV6ZY5CFGC6PJ",
        // Production WorkOS environment (soulful-path-50), distinct from preview's
        // staging environment. WORKOS_CLI_AUDIENCE is the environment OIDC client
        // stamped into the Connect token `aud` (WorkOS exposes no claim for the OAuth
        // app id itself), so the CLI token is pinned by issuer + JWKS + this audience.
        // Tokens verify against the authkit.app JWKS/issuer, not the api.workos.com
        // dashboard path. All public identifiers; safe in vars.
        "WORKOS_CLI_AUDIENCE": "client_01KSAGD5VSVFATV6ZY5CFGC6PJ",
        "WORKOS_CLI_JWKS_URL": "https://soulful-path-50.authkit.app/oauth2/jwks",
        "WORKOS_CLI_ISSUER": "https://soulful-path-50.authkit.app",
        "WORKOS_MCP_AUDIENCE": "https://mcp.agent-paste.sh",
        "WORKOS_MCP_JWKS_URL": "https://soulful-path-50.authkit.app/oauth2/jwks",
        "WORKOS_MCP_ISSUER": "https://soulful-path-50.authkit.app",
        // Cloudflare Access app protecting production operator web/API paths.
        // The corresponding routes are path-gated at the edge, and api can use
        // these to verify Cf-Access-Jwt-Assertion for service-token operator
        // identities. Keep the Access AUD in a Wrangler secret because secret
        // scanning treats the high-entropy identifier as sensitive.
        "CF_ACCESS_TEAM_DOMAIN": "zaks-io.cloudflareaccess.com"
      },
      "hyperdrive": [
        {
          "binding": "DB",
          "id": "ca07f5b895084f60b666586c362982fc"
        }
      ],
      "r2_buckets": [
        {
          "binding": "ARTIFACTS",
          "bucket_name": "agent-paste-artifacts-production"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "DENYLIST",
          "id": "86d8b139223e45108d320533277a235d"
        }
      ],
      "ratelimits": [
        {
          "name": "ACTOR_RATE_LIMIT",
          "namespace_id": "3000001",
          "simple": {
            "limit": 60,
            "period": 60
          }
        },
        {
          "name": "WORKSPACE_BURST_CAP",
          "namespace_id": "3000002",
          "simple": {
            "limit": 300,
            "period": 10
          }
        },
        {
          "name": "ARTIFACT_RATE_LIMIT",
          "namespace_id": "3000003",
          "simple": {
            "limit": 60,
            "period": 60
          }
        },
        {
          "name": "EPHEMERAL_PROVISION_IP_RATE_LIMIT",
          "namespace_id": "3000004",
          "simple": {
            "limit": 10,
            "period": 60
          }
        },
        {
          "name": "EPHEMERAL_PROVISION_GLOBAL_RATE_LIMIT",
          "namespace_id": "3000005",
          "simple": {
            "limit": 17,
            "period": 60
          }
        }
      ],
      "queues": {
        "producers": [
          { "queue": "bundle-generate-production", "binding": "BUNDLE_GENERATE_QUEUE" },
          { "queue": "safety-scan-production", "binding": "SAFETY_SCAN_QUEUE" }
        ]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "ARTIFACT_LIVE",
            "class_name": "ArtifactLiveUpdates",
            "script_name": "agent-paste-stream-production"
          },
          {
            "name": "WRITE_ALLOWANCE",
            "class_name": "WorkspaceWriteAllowance"
          }
        ]
      }
    }
  }
}
