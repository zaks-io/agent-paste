# Copy to .env for local CLI smoke tests.
#
# The current MVP vertical slice is covered by Vitest with in-memory services.
# When running the CLI against local Workers, create a workspace/API key through
# the admin API first, then set the returned API key here.

AGENT_PASTE_API_URL=http://127.0.0.1:8787
AGENT_PASTE_UPLOAD_URL=http://127.0.0.1:8788
AGENT_PASTE_ADMIN_URL=http://127.0.0.1:8787
AGENT_PASTE_API_KEY=
AGENT_PASTE_ADMIN_TOKEN=local-admin-token

# Planned persistent local services. docker-compose.yml exposes this Postgres
# database, but the current MVP tests use in-memory storage.
DATABASE_URL=postgres://agent_paste:agent_paste@127.0.0.1:5432/agent_paste
PREVIEW_DATABASE_URL=
PRODUCTION_DATABASE_URL=

# Hosted smoke tests.
AGENT_PASTE_PREVIEW_ADMIN_TOKEN=
AGENT_PASTE_PRODUCTION_ADMIN_TOKEN=
AGENT_PASTE_PREVIEW_API_URL=https://agent-paste-api-preview.isaac-a46.workers.dev
AGENT_PASTE_PREVIEW_UPLOAD_URL=https://agent-paste-upload-preview.isaac-a46.workers.dev
AGENT_PASTE_PREVIEW_CONTENT_URL=https://agent-paste-content-preview.isaac-a46.workers.dev
AGENT_PASTE_PRODUCTION_API_URL=https://api.agent-paste.sh
AGENT_PASTE_PRODUCTION_UPLOAD_URL=https://upload.agent-paste.sh
AGENT_PASTE_PRODUCTION_CONTENT_URL=https://usercontent.agent-paste.sh

# GitHub Actions variables/secrets used by dynamic PR previews.
CLOUDFLARE_WORKERS_SUBDOMAIN=isaac-a46
NEON_PROJECT_ID=
NEON_API_KEY=

# Shared dev secrets used by Worker .dev.vars examples.
API_KEY_PEPPER=dev-api-key-pepper-change-me
CONTENT_SIGNING_SECRET=dev-content-signing-secret-change-me
UPLOAD_SIGNING_SECRET=dev-upload-signing-secret-change-me
