{
  "name": "@agent-paste/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm typecheck",
    "lint": "biome lint .",
    "openapi:check": "node ../../scripts/openapi-goldens.mjs",
    "openapi:write": "node ../../scripts/openapi-goldens.mjs --write",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-paste/config": "workspace:*",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
