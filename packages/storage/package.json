{
  "name": "@agent-paste/storage",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./test-helpers/encrypted-artifact-fixture": {
      "types": "./src/test-helpers/encrypted-artifact-fixture.ts",
      "import": "./src/test-helpers/encrypted-artifact-fixture.ts"
    }
  },
  "devDependencies": {
    "@agent-paste/rotation": "workspace:*",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/typescript-checker": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm typecheck && pnpm test",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.node.config.ts",
    "test:mutation": "stryker run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  }
}
