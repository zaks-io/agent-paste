{
  "name": "@agent-paste/tokens",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./crypto": {
      "types": "./src/crypto.ts",
      "import": "./dist/crypto.js"
    },
    "./content": {
      "types": "./src/content.ts",
      "import": "./dist/content.js"
    },
    "./agent-view": {
      "types": "./src/agent-view.ts",
      "import": "./dist/agent-view.js"
    },
    "./upload-url": {
      "types": "./src/upload-url.ts",
      "import": "./dist/upload-url.js"
    },
    "./access-link": {
      "types": "./src/access-link.ts",
      "import": "./dist/access-link.js"
    },
    "./crockford": {
      "types": "./src/crockford.ts",
      "import": "./dist/crockford.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm typecheck && pnpm test",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config ../../vitest.coverage.node.config.ts",
    "test:mutation": "stryker run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/typescript-checker": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
