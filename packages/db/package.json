{
  "name": "@agent-paste/db",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm typecheck && pnpm test",
    "db:check": "node scripts/introspect-check.mjs",
    "lint": "biome lint .",
    "migrate": "node scripts/migrate.mjs",
    "test": "vitest run src scripts",
    "test:coverage": "vitest run src scripts --coverage --config ../../vitest.coverage.node.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@agent-paste/commands": "workspace:*",
    "@agent-paste/config": "workspace:*",
    "@agent-paste/contracts": "workspace:*",
    "@agent-paste/rotation": "workspace:*",
    "@agent-paste/storage": "workspace:*",
    "@agent-paste/tokens": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
