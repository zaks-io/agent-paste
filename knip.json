{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreDependencies": ["cloudflare", "jscpd"],
  "ignoreExportsUsedInFile": true,
  "ignoreFiles": [
    "**/worker-configuration.d.ts",
    ".claude/skills/**",
    ".agents/skills/**",
    ".codex/skills/**",
    "apps/apex/public/**",
    "examples/local-harness/site/assets/**"
  ],
  "workspaces": {
    "apps/web": {
      "entry": ["src/server.ts"]
    },
    "apps/apex": {
      "entry": ["src/entry-server.tsx", "src/client.ts", "src/styles/apex.css"]
    }
  }
}
